# Database
DATABASE_URL=postgresql+asyncpg://turbo:changeme@db:5432/turbo_market
SYNC_DATABASE_URL=postgresql+psycopg2://turbo:changeme@db:5432/turbo_market

# Redis
REDIS_URL=redis://redis:6379/0

# Security
ADMIN_API_KEY=changeme-admin-key

# Scraper
SCRAPER_MODE=headless         # headless | cdp
CDP_URL=http://localhost:9222  # only used when SCRAPER_MODE=cdp
DELAY_SECONDS=1.5
MAX_PAGES=0                    # 0 = all pages

# Currency
AZN_PER_USD=1.7

# Celery beat schedule (cron)
FULL_SCAN_HOUR=2
FULL_SCAN_MINUTE=0
