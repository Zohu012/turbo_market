# DigitalOcean Managed Postgres (required — get from DO dashboard → Databases)
DATABASE_URL=postgresql+asyncpg://turbo:PASS@host.db.ondigitalocean.com:25060/turbo_market?sslmode=require
SYNC_DATABASE_URL=postgresql://turbo:PASS@host.db.ondigitalocean.com:25060/turbo_market?sslmode=require

# Redis (used by backend for caching only)
REDIS_URL=redis://redis:6379/0

# Auth
APP_USERNAME=admin
APP_PASSWORD=your_strong_password
SECRET_KEY=run-openssl-rand-hex-32-and-paste-here

# Currency conversion
AZN_PER_USD=1.7

# ── Local scraper only (backend/.env, not used by Docker) ─────────────────────
# SCRAPER_MODE=cdp          # cdp = connect to open Chrome | headless = no UI
# CDP_URL=http://localhost:9222
# DELAY_SECONDS=1.5
# MAX_PAGES=0               # 0 = all pages
